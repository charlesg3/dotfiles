#!/usr/bin/env bash
# Re-export logged-in YouTube cookies from the local Firefox into the Netscape
# cookies.txt that the `yt-dl-mp3` alias reads (~/Downloads/youtube.com_cookies.txt).
#
# YouTube rotates its session cookies constantly, so the exported file goes stale
# every so often and yt-dlp starts failing age-restricted videos with
# "Sign in to confirm your age". Re-run this to refresh it.
#
# Two gotchas this script handles that hand-exporting misses:
#   1. Firefox keeps its freshest cookie values in the SQLite WAL while running;
#      reading cookies.sqlite alone gives stale values that don't authenticate.
#      We copy the -wal/-shm sidecars too and checkpoint before reading.
#   2. The full cookie jar is huge (hundreds of dupes + per-app ST-* tokens) and
#      trips a 413 Request Entity Too Large. We keep one of each cookie name.
#
# Usage:
#   ./scripts/refresh-yt-cookies [[user@]host ...]
#
# With no args it only refreshes the local file. Each host given also gets the
# file copied to ~/Downloads/youtube.com_cookies.txt on that machine via scp.
#   ./scripts/refresh-yt-cookies            # local only
#   ./scripts/refresh-yt-cookies phil       # local + phil

set -e

DOTFILES="$(cd "$(dirname "$0")/.." && pwd)"
. "$DOTFILES/common.sh"

COOKIE_DEST="Downloads/youtube.com_cookies.txt"   # relative to $HOME on every machine
LOGIN_NAMES="'LOGIN_INFO','SID','HSID','SSID','__Secure-3PSID','SAPISID'"

# --- locate the Firefox profiles directory (macOS / Linux) ------------------
if [[ "$OSTYPE" == darwin* ]]; then
    FF_DIR="$HOME/Library/Application Support/Firefox/Profiles"
else
    FF_DIR="$HOME/.mozilla/firefox"
fi

if [[ ! -d "$FF_DIR" ]]; then
    err "Firefox profiles not found at: $FF_DIR"
    exit 1
fi
command -v sqlite3 >/dev/null || { err "sqlite3 not found on PATH"; exit 1; }

header "Refreshing YouTube cookies from Firefox"

TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT

# --- pick the profile that actually has a logged-in YouTube session ---------
PROFILE=""
BEST=0
for db in "$FF_DIR"/*/cookies.sqlite; do
    [[ -f "$db" ]] || continue
    prof="$(dirname "$db")"
    cp "$db" "$TMP/probe.sqlite"
    n="$(sqlite3 "$TMP/probe.sqlite" \
        "SELECT count(*) FROM moz_cookies WHERE host LIKE '%youtube.com' AND name IN ($LOGIN_NAMES);" 2>/dev/null || echo 0)"
    if (( n > BEST )); then BEST=$n; PROFILE="$prof"; fi
done

if [[ -z "$PROFILE" || "$BEST" -eq 0 ]]; then
    err "No Firefox profile has YouTube login cookies."
    err "Log in to YouTube in Firefox, then re-run."
    exit 1
fi
ok "Using profile: ${DIM}$(basename "$PROFILE")${RESET} ($BEST login cookies)"

# --- copy DB + WAL/SHM sidecars and checkpoint so we read fresh values ------
cp "$PROFILE/cookies.sqlite" "$TMP/c.sqlite"
cp "$PROFILE/cookies.sqlite-wal" "$TMP/c.sqlite-wal" 2>/dev/null || true
cp "$PROFILE/cookies.sqlite-shm" "$TMP/c.sqlite-shm" 2>/dev/null || true
sqlite3 "$TMP/c.sqlite" "PRAGMA wal_checkpoint(TRUNCATE);" >/dev/null 2>&1 || true

# --- export to Netscape cookies.txt, one row per cookie name ----------------
OUT="$TMP/youtube.com_cookies.txt"
{
    echo "# Netscape HTTP Cookie File"
    echo "# This file is generated by refresh-yt-cookies.  Do not edit."
    echo ""
    # Prefer the .youtube.com (dotted) host, path '/', longest value; awk keeps
    # the first row seen per cookie name. ST-* are throwaway per-app tokens.
    sqlite3 -separator "$(printf '\t')" "$TMP/c.sqlite" \
        "SELECT host,
                CASE WHEN substr(host,1,1)='.' THEN 'TRUE' ELSE 'FALSE' END,
                path,
                CASE WHEN isSecure THEN 'TRUE' ELSE 'FALSE' END,
                CASE WHEN expiry IS NULL OR expiry=0 THEN 0 ELSE expiry END,
                name, value
         FROM moz_cookies
         WHERE host LIKE '%youtube.com' AND name NOT LIKE 'ST-%'
         ORDER BY (substr(host,1,1)='.') DESC, (path='/') DESC, length(value) DESC;" \
    | awk -F'\t' '!seen[$6]++'
} > "$OUT"

if ! grep -q "LOGIN_INFO" "$OUT"; then
    err "Export is missing LOGIN_INFO — cookies would not authenticate. Aborting."
    exit 1
fi
COUNT="$(grep -vc '^#' "$OUT" || true)"
ok "Exported $COUNT cookies"

# --- install locally --------------------------------------------------------
cp "$OUT" "$HOME/$COOKIE_DEST"
ok "Wrote ~/$COOKIE_DEST"

# --- push to any remotes given ----------------------------------------------
for host in "$@"; do
    _spin "copying to $host"
    if scp -q "$OUT" "$host:$COOKIE_DEST" 2>/dev/null; then
        _clear_spin; ok "Copied to $host:~/$COOKIE_DEST"
    else
        _clear_spin; err "Failed to copy to $host"
    fi
done

echo -e "\n${BOLD}${GREEN}Done!${RESET} yt-dl-mp3 should work again."
